// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      "space f p": "file_finder::Toggle",
      "space f o": "editor::OpenPermalinkToLine",
      "alt-h": "workspace::ActivatePaneLeft",
      "alt-j": "workspace::ActivatePaneDown",
      "alt-k": "workspace::ActivatePaneUp",
      "alt-l": "workspace::ActivatePaneRight",
    },
  },
  {
    "context": "GitPanel || ProjectPanel || CollabPanel || OutlinePanel || ChatPanel || VimControl || EmptyPane || SharedScreen || MarkdownPreview || KeyContextView",
    "bindings": {
      "ctrl-w ctrl-c": "pane::CloseAllItems",
    },
  },
  {
    "context": "Workspace",
    "unbind": {
      "ctrl-tab": "tab_switcher::Toggle",
      "ctrl-shift-tab": [
        "tab_switcher::Toggle",
        {
          "select_last": true,
        },
      ],
      "cmd-1": ["workspace::ActivatePane", 0],
      "cmd-2": ["workspace::ActivatePane", 0],
      "cmd-3": ["workspace::ActivatePane", 0],
      "cmd-4": ["workspace::ActivatePane", 0],
      "cmd-5": ["workspace::ActivatePane", 0],
      "cmd-6": ["workspace::ActivatePane", 0],
      "cmd-7": ["workspace::ActivatePane", 0],
      "cmd-8": ["workspace::ActivatePane", 0],
      "cmd-9": ["workspace::ActivatePane", 0],
    },
  },
]
