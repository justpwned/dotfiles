set nocompatible
syntax on

set encoding=utf-8
set belloff=all
set novb

set wrap
set number
set ruler

set tabstop=4
set shiftwidth=4
set softtabstop=4
set guifont=Consolas:h10

set laststatus=2
set hlsearch
set ignorecase
set incsearch

"Keybindings

"<Ctrl-l> redraws the screen and removes any search highlighting
noremap <silent> <C-l> :nohl<CR><C-l>

"<Ctrl-s> saves file, but only when it has been modified
inoremap <silent> <C-s>		<Esc>:update<CR>
noremap  <silent> <C-s>		:update<CR>

"Python execution
inoremap <F5> <Esc>:update<CR>:!python %<CR>
nnoremap <F5> <Esc>:update<CR>:!python %<CR>

set backspace=indent,eol,start
